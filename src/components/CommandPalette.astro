---
import SocialLinks from './SocialLinks.astro';
---
<div class="magnetic-wrap animate" id="menu-wrap">
  <button class="cmd-btn" id="cmdBtn" aria-label="Open Menu">
    <i data-lucide="chart-no-axes-gantt" id="menu-icon" style="width: 18px; height: 18px; flex-shrink: 0;"></i>
    <span class="cmd-btn-label">MENU</span>
  </button>
</div>

<div class="modal-overlay" id="modalOverlay">
  <div class="modal-content">

    <!-- Top Header (Replaces Search) -->
    <div class="cp-search" style="justify-content: space-between; padding: 10px 16px;">
      <div class="cp-time">
        <div class="cp-dot"></div>
        <span id="modalTime" style="font-size: 9px;">Ecuador, --:--</span>
      </div>
      <div style="display: flex; gap: 14px; align-items: center;">
        <SocialLinks className="cp-social-link" />
      </div>
    </div>

    <!-- Scrollable list -->
    <div class="cp-body" id="cmd-list">



      <div class="cp-group" data-group="pages">
        <div class="cp-label">[NAV] Pages</div>
        <a href="/portfolio" class="cp-row">
          <span class="cp-title" data-t="portfolio_home">Portfolio Home</span>
          <span class="cp-meta">/portfolio</span>
        </a>
        <a href="/" class="cp-row">
          <span class="cp-title" data-t="links">Linktree</span>
          <span class="cp-meta">/</span>
        </a>
        <a href="/portfolio/about" class="cp-row">
          <span class="cp-title" data-t="about">About</span>
          <span class="cp-meta">/portfolio/about</span>
        </a>
        <a href="/portfolio/now" class="cp-row">
          <span class="cp-title">Now</span>
          <span class="cp-meta">/portfolio/now</span>
        </a>
        <a href="/portfolio/skills" class="cp-row">
          <span class="cp-title" data-t="skills">Skills</span>
          <span class="cp-meta">/portfolio/skills</span>
        </a>
        <a href="/portfolio/experience" class="cp-row">
          <span class="cp-title" data-t="experience">Experience</span>
          <span class="cp-meta">/portfolio/experience</span>
        </a>
        <a href="/portfolio/education" class="cp-row">
          <span class="cp-title" data-t="education">Education</span>
          <span class="cp-meta">/portfolio/education</span>
        </a>
        <a href="/portfolio/certifications" class="cp-row">
          <span class="cp-title" data-t="certifications">Certifications</span>
          <span class="cp-meta">/portfolio/certifications</span>
        </a>
        <a href="/portfolio/leadership" class="cp-row">
          <span class="cp-title" data-t="leadership">Leadership</span>
          <span class="cp-meta">/portfolio/leadership</span>
        </a>
        <a href="/portfolio/blog" class="cp-row">
          <span class="cp-title" data-t="blog">Blog</span>
          <span class="cp-meta">/portfolio/blog</span>
        </a>
      </div>

    </div>


  </div>
</div>
