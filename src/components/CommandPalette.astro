    <!-- Scrollable list -->
    <div class="cp-body" id="cmd-list">



      <div class="cp-group" data-group="pages">
        <div class="cp-label">[NAV] Pages</div>
        <a href="/" class="cp-row" data-search="home inicio principal overview">
          <span class="cp-title" data-t="home">Home</span>
          <span class="cp-meta">/</span>
        </a>
        <a href="/about" class="cp-row" data-search="about sobre mi perfil profile">
          <span class="cp-title" data-t="about">About</span>
          <span class="cp-meta">/about</span>
        </a>
        <a href="/now" class="cp-row" data-search="now ahora working learning currently">
          <span class="cp-title">Now</span>
          <span class="cp-meta">/now</span>
        </a>
        <a href="/skills" class="cp-row" data-search="skills habilidades sql python power bi azure">
          <span class="cp-title" data-t="skills">Skills</span>
          <span class="cp-meta">/skills</span>
        </a>
        <a href="/experience" class="cp-row" data-search="experience experiencia work trabajo">
          <span class="cp-title" data-t="experience">Experience</span>
          <span class="cp-meta">/experience</span>
        </a>
        <a href="/education" class="cp-row" data-search="education educacion universidad university">
          <span class="cp-title" data-t="education">Education</span>
          <span class="cp-meta">/education</span>
        </a>
        <a href="/certifications" class="cp-row" data-search="certifications certificaciones microsoft google">
          <span class="cp-title" data-t="certifications">Certifications</span>
          <span class="cp-meta">/certifications</span>
        </a>
        <a href="/leadership" class="cp-row" data-search="leadership liderazgo ambassador microsoft mentor">
          <span class="cp-title" data-t="leadership">Leadership</span>
          <span class="cp-meta">/leadership</span>
        </a>
        <a href="/blog" class="cp-row" data-search="blog writing posts data analytics articles">
          <span class="cp-title" data-t="blog">Blog</span>
          <span class="cp-meta">/blog</span>
        </a>
      </div>



      <!-- Empty state -->
      <div class="cp-empty" id="cmd-empty">No results found.</div>

    </div>


  </div>
</div>



<script is:inline>
  function initCmdSearch() {
    const input = document.getElementById('cmd-search');
    const list = document.getElementById('cmd-list');
    const emptyEl = document.getElementById('cmd-empty');
    if (!input || !list) return;

    let selIdx = -1;
    let visible = [];

    const overlay = document.getElementById('modalOverlay');
    if (overlay) {
      new MutationObserver(() => {
        if (overlay.classList.contains('active')) {
          setTimeout(() => input.focus(), 50);
        } else {
          input.value = '';
          run('');
        }
      }).observe(overlay, { attributes: true, attributeFilter: ['class'] });
    }

    function run(q) {
      q = q.toLowerCase().trim();
      const rows = list.querySelectorAll('.cp-row[data-search]');
      const groups = list.querySelectorAll('.cp-group');
      visible = [];
      selIdx = -1;

      rows.forEach(r => {
        const hay = (r.getAttribute('data-search') + ' ' + r.textContent).toLowerCase();
        const ok = !q || hay.includes(q);
        r.style.display = ok ? '' : 'none';
        r.classList.remove('cp-active');
        if (ok) visible.push(r);
      });

      groups.forEach(g => {
        const any = [...g.querySelectorAll('.cp-row')].some(r => r.style.display !== 'none');
        g.style.display = any ? '' : 'none';
      });

      if (emptyEl) emptyEl.style.display = visible.length ? 'none' : 'block';

      if (q && visible.length) {
        selIdx = 0;
        visible[0].classList.add('cp-active');
      }
    }

    function move(d) {
      if (!visible.length) return;
      if (selIdx >= 0) visible[selIdx].classList.remove('cp-active');
      selIdx = (selIdx + d + visible.length) % visible.length;
      visible[selIdx].classList.add('cp-active');
      visible[selIdx].scrollIntoView({ block: 'nearest' });
    }

    function go() {
      const el = visible[selIdx];
      if (!el) return;
      el.tagName === 'A' ? el.click() : el.dispatchEvent(new MouseEvent('click', { bubbles: true }));
    }

    input.addEventListener('input', e => run(e.target.value));
    input.addEventListener('keydown', e => {
      if (e.key === 'ArrowDown') { e.preventDefault(); move(1); }
      if (e.key === 'ArrowUp') { e.preventDefault(); move(-1); }
      if (e.key === 'Enter') { e.preventDefault(); go(); }
    });

    run('');
  }

  document.addEventListener('astro:after-swap', initCmdSearch);
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initCmdSearch);
  else initCmdSearch();
</script>