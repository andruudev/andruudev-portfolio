---
---
<header class="header animate">
  <div style="display: flex; align-items: flex-start; gap: 20px;">
    <a href="/" class="nav-link">
      <img src="/andruudev-portfolio/assets/andruudev-profile.png" alt="Jeyson Andrés Mueses photo profile-info" class="avatar"
        style="width: 64px; height: 64px;" />
    </a>
    <div class="profile-info-wrap">
      <div class="profile-info">
        <a href="/" class="nav-link" style="flex-direction: column; align-items: flex-start; gap: 4px;">
          <h1 style="font-size: 20px; font-weight: 500; letter-spacing: -0.02em; margin: 0;">Jeyson Andrés Mueses 🇪🇨</h1>
          <p style="color: var(--text-secondary); font-size: 12px; margin: 0;">Data Analyst & BI Developer | Microsoft Student Ambassador </p>
        </a>
      </div>
      <div class="header-socials" style="margin-top: 12px; justify-content: flex-start; gap: 14px;">
        <a href="https://github.com/andruudev" target="_blank" aria-label="GitHub">
          <i data-lucide="github" style="width: 14px; height: 14px;"></i>
        </a>
        <a href="https://x.com/andruudev" target="_blank" aria-label="X (Twitter)">
          <i data-lucide="twitter" style="width: 14px; height: 14px;"></i>
        </a>
        <a href="https://instagram.com/andruudev" target="_blank" aria-label="Instagram">
          <i data-lucide="instagram" style="width: 14px; height: 14px;"></i>
        </a>
        <a href="https://linkedin.com/in/andruudev" target="_blank" aria-label="LinkedIn">
          <i data-lucide="linkedin" style="width: 14px; height: 14px;"></i>
        </a>
        <a href="https://youtube.com/@andruudev" target="_blank" aria-label="YouTube">
          <i data-lucide="youtube" style="width: 14px; height: 14px;"></i>
        </a>
        <a href="https://tiktok.com/@andruudev" target="_blank" aria-label="TikTok">
          <i data-lucide="music-2" style="width: 14px; height: 14px;"></i>
        </a>
        <a href="mailto:andruudev@gmail.com" aria-label="Email">
          <i data-lucide="mail" style="width: 14px; height: 14px;"></i>
        </a>
        <a href="https://calendar.app.google/x4k7jeHac8j5fP5X6" target="_blank" class="book-btn"
          aria-label="Book Appointment">
          <i data-lucide="calendar" style="width: 12px; height: 12px;"></i> Book Appointment
        </a>
      </div>
    </div>
  </div>
</header>
