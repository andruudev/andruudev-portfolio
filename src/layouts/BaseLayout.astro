---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import LangToggle from "../components/LangToggle.astro";
import CommandPalette from "../components/CommandPalette.astro";

interface Props {
	title?: string;
	description?: string;
	lang?: string;
	hideHeader?: boolean;
	hideFooter?: boolean;
	hideMenu?: boolean;
}

const {
	title = "Jeyson Andrés Mueses | Portfolio | Data & Cloud Engineer",
	description = "Data & Cloud Engineer focused on cloud databases, automated ETL pipelines, and scalable data architectures.",
	lang = "en",
	hideHeader = false,
	hideFooter = false,
	hideMenu = false,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/assets/logo-andruudev.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Open Graph / Social Preview -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://andruudev.github.io" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta
			property="og:image"
			content="https://andruudev.github.io/assets/og-image.png"
		/>
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@andruudev" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta
			name="twitter:image"
			content="https://andruudev.github.io/assets/og-image.png"
		/>

		<!-- Fix FOUC: apply saved theme BEFORE first paint -->
		<script is:inline>
			(function () {
				var saved = localStorage.getItem("theme") || "light";
				document.documentElement.setAttribute("data-theme", saved);
			})();
		</script>

		<script
			is:inline
			src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
		></script>
		<script
			is:inline
			src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
		></script>
		<script is:inline src="https://unpkg.com/lenis@1.1.2/dist/lenis.min.js"
		></script>
		<script is:inline src="https://unpkg.com/lucide@latest"></script>

		<ClientRouter />
	</head>
	<body>
		<div id="system-preloader">
			<div class="preloader-content">
				<div class="preloader-text" data-t="system_initializing">
					SYSTEM_INITIALIZING...
				</div>
				<div class="preloader-bar-bg">
					<div class="preloader-bar"></div>
				</div>
				<div class="preloader-status" data-t="encrypting_session">
					ENCRYPTING_SESSION...
				</div>
			</div>
		</div>

		<div id="transition-overlay">
			<div class="transition-column"></div>
			<div class="transition-column"></div>
			<div class="transition-column"></div>
			<div class="transition-column"></div>
			<div class="transition-column"></div>
		</div>

		<div id="progress-bar"></div>
		<div id="cursor"></div>
		<div id="project-preview"></div>
		<canvas id="noiseCanvas"></canvas>

		<ThemeToggle />
		<LangToggle />
		{!hideMenu && <CommandPalette />}

		<!-- Mobile Unified Nav Bar -->
		<div id="mobile-nav-bar">
			<!-- Theme -->
			<button
				class="mobile-nav-btn"
				id="mobileThemeBtn"
				aria-label="Toggle theme"
			>
				<svg
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<circle cx="12" cy="12" r="4"></circle>
					<path
						d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
					></path>
				</svg>
				<span class="mobile-nav-label" id="mobileThemeLabel">Light</span
				>
			</button>

			<div class="mobile-nav-divider"></div>

			<!-- Language -->
			<button
				class="mobile-nav-btn"
				id="mobileLangBtn"
				aria-label="Toggle language"
			>
				<svg
					width="16"
					height="16"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<circle cx="12" cy="12" r="10"></circle>
					<path
						d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
					></path>
					<path d="M2 12h20"></path>
				</svg>
				<span class="mobile-nav-label" id="mobileLangLabel">EN</span>
			</button>

			{!hideMenu && <div class="mobile-nav-divider"></div>}

			<!-- Menu -->
			{!hideMenu && (
				<button
					class="mobile-nav-btn"
					id="mobileMenuBtn"
					aria-label="Open menu"
				>
					<svg
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						id="mobileMenuIcon"
					>
						<line x1="4" y1="6" x2="20" y2="6"></line>
						<line x1="4" y1="12" x2="20" y2="12"></line>
						<line x1="4" y1="18" x2="20" y2="18"></line>
					</svg>
					<span class="mobile-nav-label">Menu</span>
				</button>
			)}
		</div>

		<div class="container">
			{!hideHeader && <Header />}
			<main id="app">
				<slot />
			</main>
			{!hideFooter && <Footer />}
		</div>

