---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={`${entry.data.title} | Blog`}>
  <article class="animate">
    <span class="section-label">[12] Blog Post</span>
    <h1 style="font-family: var(--font-sans); font-size: 32px; margin-bottom: 8px;">{entry.data.title}</h1>
    <p style="color: var(--text-secondary); font-family: var(--font-mono); font-size: 12px; margin-bottom: 32px;">{entry.data.date} — {entry.data.tag}</p>
    
    <div class="content-text blog-content">
      <Content />
    </div>
  </article>

  <div style="margin-top: 40px; border-top: 1px solid var(--border-color); padding-top: 24px;">
    <a href="/portfolio/blog" class="nav-link" style="color: var(--text-secondary); font-family: var(--font-mono); font-size: 13px; text-decoration: none;"><i data-lucide="arrow-left"></i> Back to Blog</a>
  </div>
</BaseLayout>

<style is:global>
  .blog-content h2 { 
    margin-top: 36px; 
    margin-bottom: 16px; 
    font-size: 20px; 
    font-family: var(--font-sans); 
    font-weight: 600;
    color: var(--text-color);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 8px;
  }
  .blog-content h3 { 
    margin-top: 28px; 
    margin-bottom: 12px; 
    font-size: 16px; 
    font-family: var(--font-sans); 
    font-weight: 600;
    color: var(--text-color);
  }
  .blog-content p { 
    margin-bottom: 18px; 
    line-height: 1.7; 
    color: var(--text-color);
    opacity: 0.9;
  }
  .blog-content ul { 
    margin-bottom: 18px; 
    padding-left: 24px; 
    line-height: 1.7;
    color: var(--text-color);
  }
  .blog-content li {
    margin-bottom: 8px;
  }
  .blog-content img {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 32px auto;
    display: block;
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.25);
    border: 1px solid var(--border-color);
  }
  [data-theme='light'] .blog-content img {
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.08);
  }
  .blog-content blockquote {
    margin: 28px 0;
    padding: 16px 20px;
    background-color: rgba(255, 255, 255, 0.02);
    border-left: 3px solid var(--text-color);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: var(--text-secondary);
  }
  [data-theme='light'] .blog-content blockquote {
    background-color: rgba(0, 0, 0, 0.02);
  }
  .blog-content blockquote p {
    margin-bottom: 0;
  }
  .blog-content pre {
    padding: 18px;
    border-radius: 8px;
    background-color: rgba(255, 255, 255, 0.02) !important;
    border: 1px solid var(--border-color);
    overflow-x: auto;
    margin: 28px 0;
  }
  [data-theme='light'] .blog-content pre {
    background-color: rgba(0, 0, 0, 0.015) !important;
  }
  .blog-content code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 3px 6px;
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    border: 1px solid var(--border-color);
    color: var(--text-color);
  }
  [data-theme='light'] .blog-content code {
    background-color: rgba(0, 0, 0, 0.035);
  }
  .blog-content pre code {
    padding: 0;
    background-color: transparent;
    border: none;
    font-size: 13px;
    color: inherit;
  }
  .blog-content hr {
    margin: 40px 0;
    border: 0;
    border-top: 1px solid var(--border-color);
  }
</style>
