---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Blog | Jeyson Andrés Mueses">
  <section class="animate">
    <span class="section-label" data-t="blog_label">[12] Blog</span>
    <h2 style="font-family: var(--font-sans); font-size: 24px; margin-bottom: 24px;" data-t="blog_title">Field Notes</h2>
    <div class="items-list">
      {sortedPosts.map(post => (
        <a href={`/portfolio/blog/${post.id}`} class="item">
          <span class="item-title"><i data-lucide="book-text"></i> {post.data.title}</span>
          <span class="item-meta">{post.data.date}</span>
        </a>
      ))}
    </div>
  </section>

  <div style="margin-top: 40px;">
    <a href="/portfolio" class="nav-link" style="color: var(--text-secondary); font-family: var(--font-mono); font-size: 13px; text-decoration: none;" data-t="back_home"><i data-lucide="arrow-left"></i> Back to Home</a>
  </div>
</BaseLayout>
