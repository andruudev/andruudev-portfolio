---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Leadership | Jeyson Andrés Mueses">
  <section class="animate">
    <span class="section-label" data-t="leadership_label">[11] Leadership</span>
    <h2 style="font-family: var(--font-sans); font-size: 24px; margin-bottom: 24px;" data-t="leadership_title">Leadership & Volunteering</h2>

    <div class="items-list">
      <div class="item" style="flex-direction: column; align-items: flex-start; gap: 4px; padding: 16px 0; border-bottom: 1px solid var(--border-color);">
        <div class="item-header">
          <span style="font-weight: 500;">Microsoft Student Ambassador (MLSA)</span>
          <span style="font-family: var(--font-mono); font-size: 11px; color: var(--text-secondary);">2023 — Present</span>
        </div>
        <span style="font-size: 13px; color: var(--text-secondary);">Microsoft · Ecuador</span>
        <p style="font-size: 14px; margin-top: 8px; line-height: 1.7;">Organizing workshops and technical sessions on Azure, Power BI, and data analytics for university students across Ecuador. Reached 300+ students through in-person and virtual events in 2024.</p>
      </div>

      <div class="item" style="flex-direction: column; align-items: flex-start; gap: 4px; padding: 16px 0; border-bottom: 1px solid var(--border-color);">
        <div class="item-header">
          <span style="font-weight: 500;">Data Mentor</span>
          <span style="font-family: var(--font-mono); font-size: 11px; color: var(--text-secondary);">2022 — Present</span>
        </div>
        <span style="font-size: 13px; color: var(--text-secondary);">ADPList · Remote</span>
        <p style="font-size: 14px; margin-top: 8px; line-height: 1.7;">Mentoring junior analysts and career-switchers entering the data field. Topics include SQL, Power BI, interview preparation, and portfolio reviews. 50+ sessions completed.</p>
      </div>

      <div class="item" style="flex-direction: column; align-items: flex-start; gap: 4px; padding: 16px 0;">
        <div class="item-header">
          <span style="font-weight: 500;">Tech Community Organizer</span>
          <span style="font-family: var(--font-mono); font-size: 11px; color: var(--text-secondary);">2022 — 2023</span>
        </div>
        <span style="font-size: 13px; color: var(--text-secondary);">DataQuito · Quito, Ecuador</span>
        <p style="font-size: 14px; margin-top: 8px; line-height: 1.7;">Co-founded and organized a local data community in Quito. Ran monthly meetups on data engineering, analytics, and BI tooling, growing the community from 0 to 180 active members.</p>
      </div>
    </div>
  </section>

  <div style="margin-top: 40px;">
    <a href="/portfolio" class="nav-link" style="color: var(--text-secondary); font-family: var(--font-mono); font-size: 13px; text-decoration: none;" data-t="back_home"><i data-lucide="arrow-left"></i> Back to Home</a>
  </div>
</BaseLayout>
