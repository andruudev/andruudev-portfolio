---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Skills | Jeyson Andrés Mueses">
  <section class="animate">
    <span class="section-label" data-t="skills_label">[07] Skills</span>
    <h2 style="font-family: var(--font-sans); font-size: 24px; margin-bottom: 8px;" data-t="skills_title">Technical Skills</h2>
    <p style="font-size: 14px; color: var(--text-secondary); margin-bottom: 32px;">Tools and technologies I work with daily across the data lifecycle.</p>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 32px;">
      <div>
        <h3 style="font-family: var(--font-mono); font-size: 11px; color: var(--text-secondary); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;">BI & Visualization</h3>
        <ul style="list-style: none; font-size: 14px; display: flex; flex-direction: column; gap: 8px;">
          <li>Power BI</li>
          <li>Tableau</li>
          <li>Looker Studio</li>
          <li>DAX / Power Query (M)</li>
          <li>Excel (Advanced)</li>
        </ul>
      </div>
      <div>
        <h3 style="font-family: var(--font-mono); font-size: 11px; color: var(--text-secondary); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;">Data Engineering</h3>
        <ul style="list-style: none; font-size: 14px; display: flex; flex-direction: column; gap: 8px;">
          <li>SQL / T-SQL</li>
          <li>Python (Pandas, NumPy)</li>
          <li>ETL Pipelines</li>
          <li>Azure Data Factory</li>
          <li>Azure Databricks</li>
        </ul>
      </div>
      <div>
        <h3 style="font-family: var(--font-mono); font-size: 11px; color: var(--text-secondary); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;">Databases & Cloud</h3>
        <ul style="list-style: none; font-size: 14px; display: flex; flex-direction: column; gap: 8px;">
          <li>SQL Server</li>
          <li>PostgreSQL</li>
          <li>Azure Synapse Analytics</li>
          <li>Azure Blob Storage</li>
          <li>Git / GitHub</li>
        </ul>
      </div>
    </div>
  </section>

  <div style="margin-top: 40px;">
    <a href="/" class="nav-link" style="color: var(--text-secondary); font-family: var(--font-mono); font-size: 13px; text-decoration: none;" data-t="back_home"><i data-lucide="arrow-left"></i> Back to Home</a>
  </div>
</BaseLayout>
